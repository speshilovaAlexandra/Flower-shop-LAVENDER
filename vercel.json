{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://speshisq.beget.tech/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "http://speshisq.beget.tech/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/storage/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/webp"
        }
      ]
    }
  ]
}
